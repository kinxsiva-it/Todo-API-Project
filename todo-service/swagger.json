{
  "openapi": "3.0.0",
  "info": {
    "title": "Todo API",
    "version": "1.1.0",
    "description": "เอกสารระบบ API สำหรับจัดการ Todo List (รองรับ Refresh Token และ RBAC)"
  },
  "components": {
    "securitySchemes": {
      "csrfToken": {
        "type": "apiKey",
        "in": "header",
        "name": "X-CSRF-Token",
        "description": "ยิง GET /api/csrf-token แล้วนำค่า csrfToken มาใส่ที่นี่"
      }
    }
  },
  "security": [ { "csrfToken": [] } ],
  "servers": [ { "url": "http://localhost:3000" } ],
  "paths": {
    "/api/auth/register": {
      "post": {
        "summary": "ลงทะเบียนผู้ใช้ใหม่",
        "tags": ["Auth"],
        "security": [{ "csrfToken": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "example": "test@nilecon.com" },
                  "password": { "type": "string", "example": "password123" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "ลงทะเบียนสำเร็จ" } }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "เข้าสู่ระบบเพื่อรับ Token (Access & Refresh)",
        "tags": ["Auth"],
        "security": [{ "csrfToken": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "example": "testuser@example.com" },
                  "password": { "type": "string", "example": "password123" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "เข้าสู่ระบบสำเร็จ (คืนค่า Token ผ่าน Cookie)" } }
      }
    },
    "/api/auth/refresh-token": {
      "post": {
        "summary": "ขอ Access Token ก้อนใหม่ด้วย Refresh Token",
        "description": "ใช้ Refresh Token ที่อยู่ใน Cookie เพื่อขอ Access Token ใหม่เมื่อตัวเก่าหมดอายุ",
        "tags": ["Auth"],
        "security": [{ "csrfToken": [] }],
        "responses": { 
          "200": { "description": "ออก Token ใหม่สำเร็จ" },
          "401": { "description": "ไม่มี Refresh Token ส่งมา" },
          "403": { "description": "Refresh Token ไม่ถูกต้องหรือหมดอายุ" }
        }
      }
    },
    "/api/todos": {
      "post": {
        "summary": "สร้าง Todo ใหม่",
        "tags": ["Todos"],
        "security": [{ "csrfToken": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": { "type": "string", "example": "เขียน Document" },
                  "description": { "type": "string", "example": "ทำเอกสาร API" },
                  "status": { "type": "string", "example": "PENDING" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "สร้างสำเร็จ" } }
      },
      "get": {
        "summary": "ดึงรายการ Todo ทั้งหมด",
        "tags": ["Todos"],
        "security": [{ "csrfToken": [] }],
        "parameters": [
          { "in": "query", "name": "page", "schema": { "type": "integer" }, "description": "หน้าที่ต้องการดู" },
          { "in": "query", "name": "limit", "schema": { "type": "integer" }, "description": "จำนวนรายการต่อหน้า" },
          { "in": "query", "name": "search", "schema": { "type": "string" }, "description": "ค้นหาจากชื่อ Title" },
          { "in": "query", "name": "status", "schema": { "type": "string" }, "description": "สถานะ (PENDING, IN_PROGRESS, DONE)" }
        ],
        "responses": { "200": { "description": "ดึงข้อมูลสำเร็จ" } }
      }
    },
    "/api/todos/{id}": {
      "get": {
        "summary": "ดึงรายการ Todo ตาม ID",
        "tags": ["Todos"],
        "security": [{ "csrfToken": [] }],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "ดึงข้อมูลสำเร็จ" } }
      },
      "put": {
        "summary": "อัปเดตรายการ Todo ตาม ID",
        "tags": ["Todos"],
        "security": [{ "csrfToken": [] }],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": { "type": "string", "example": "อัปเดตงาน" },
                  "status": { "type": "string", "example": "DONE" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "อัปเดตสำเร็จ" } }
      },
      "delete": {
        "summary": "ลบรายการ Todo ตาม ID (Admin Only)",
        "description": "ผู้ใช้งานต้องมี Role เป็น 'admin' เท่านั้นจึงจะสามารถใช้งาน Endpoint นี้ได้",
        "tags": ["Todos"],
        "security": [{ "csrfToken": [] }],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { 
          "200": { "description": "ลบสำเร็จ" },
          "403": { "description": "ไม่มีสิทธิ์ในการลบข้อมูล (ไม่ใช่ Admin)" }
        }
      }
    },
    "/api/logs/activity": {
      "get": {
        "summary": "ดึงประวัติกิจกรรมของผู้ใช้ (Admin Only)",
        "description": "ผู้ใช้งานต้องมี Role เป็น 'admin' เท่านั้นจึงจะสามารถดูประวัติการใช้งานระบบได้",
        "tags": ["Logs"],
        "security": [{ "csrfToken": [] }],
        "responses": { 
          "200": { "description": "ดึงข้อมูลสำเร็จ" },
          "403": { "description": "ไม่มีสิทธิ์เข้าถึง (ไม่ใช่ Admin)" }
        }
      }
    }
  }
}